# Copy this file to ".env" and fill in your values.
# The .env file is loaded automatically when uvicorn starts.
# Never commit .env to git — only this .env.example.

# ─── Google Maps ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── Podium OAuth ────────────────────────────────────────────
PODIUM_CLIENT_ID=
PODIUM_CLIENT_SECRET=

# Your current public URL (no trailing slash), e.g.
# PODIUM_REDIRECT_URI=https://fnftest.onrender.com
PODIUM_REDIRECT_URI=

# Fill this in AFTER running the OAuth flow at /oauth/start
PODIUM_REFRESH_TOKEN=

# ─── Google Calendar (optional) ──────────────────────────────
# Paste the FULL JSON contents of your service account key here.
# In Render, paste the entire JSON as the value of this env var.
# Locally, you can use a single line of escaped JSON, or load from a file.
GOOGLE_SERVICE_ACCOUNT_JSON=
