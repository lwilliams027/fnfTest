# Copy this file to ".env" and fill in your values.
# The .env file is loaded automatically when uvicorn starts.
# Never commit .env to git — only this .env.example.

# ─── Google Maps ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── Podium OAuth ────────────────────────────────────────────
PODIUM_CLIENT_ID=
PODIUM_CLIENT_SECRET=

# Your current public URL (no trailing slash), e.g.
# PODIUM_REDIRECT_URI=https://fnftest.onrender.com
PODIUM_REDIRECT_URI=

# Fill this in AFTER running the OAuth flow at /oauth/start
PODIUM_REFRESH_TOKEN=

# ─── Google Calendar OAuth (for per-injector calendar access) ─
# Get these by creating an OAuth Client ID in Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Where Google redirects after the injector authorizes.
# Must match exactly what's configured on the OAuth Client ID in GCP.
# If unset, defaults to PODIUM_REDIRECT_URI + "/oauth/google/callback"
# GOOGLE_OAUTH_REDIRECT_URI=https://fnftest.onrender.com/oauth/google/callback
